### deploy por SSH (rsync) para producao cPanel
DEPLOY_SSH_HOST=162.241.203.145
DEPLOY_SSH_PORT=2222
DEPLOY_SSH_USER=thadio58
DEPLOY_SSH_PASS=
#sempre mude o root para:
DEPLOY_SSH_REMOTE_ROOT=/home2/thadio58/reembolso.thadio.com
#ao fazer upload para o servidor, ignorar os arquivos listados nesse arquivo (ex: node_modules, .env, etc)
DEPLOY_IGNORE_FILE=.ftpignore
#por padrão, nunca deletar arquivos do servidor, mesmo que eles não existam mais localmente (ex: arquivos de log, uploads, etc)
DEPLOY_RSYNC_DELETE=0

