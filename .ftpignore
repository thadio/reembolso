# .ftpignore - padrões recomendados para upload via FTP
# Ignorar arquivos/dirs gerados localmente, dependências e segredos.

# ----------------
# Sistema / OS
# ----------------
.DS_Store
Thumbs.db

# ----------------
# Controle de versão / metadados locais
# ----------------
.git/
.gitignore
.gitattributes

# ----------------
# IDEs / editores
# ----------------
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# ----------------
# Dependências / builds
# ----------------
vendor/
composer.lock
composer.phar
node_modules/
dist/
build/
public/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml

# ----------------
# Arquivos de ambiente / segredos
# ----------------
.env
.env.*
/.env

# ----------------
# Logs, uploads e caches gerados em runtime
# ----------------
storage/logs/
storage/uploads/
storage/framework/
bootstrap/cache/
cache/
tmp/

# ----------------
# Arquivos de teste, cobertura e configs de desenvolvimento
# ----------------
phpunit.xml
phpunit.xml.dist
tests/
coverage/

# ----------------
# Documentação e itens de projeto que normalmente não precisam subir
# ----------------
docs/
_ignore/

# Arquivos de backup e pacote
*.sql
*.sqlite
*.log

# FTP / deployment
.ftpignore

# fim
