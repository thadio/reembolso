# Application
NAME="Reembolso"
BASE_URL=http://localhost:8000
TIMEZONE=America/Sao_Paulo
APP_ENV=local
APP_DEBUG=1

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=reembolso
DB_USER=reembolso_user
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Session and CSRF
SESSION_NAME=reembolso_session
SESSION_TTL_SECONDS=7200
CSRF_TTL_SECONDS=7200

# Login rate-limit
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900
# Legacy fallback (if LOGIN_WINDOW_SECONDS/LOGIN_LOCKOUT_SECONDS are not set)
LOGIN_DECAY_SECONDS=900

# Security policy defaults (phase 6.3)
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPER=0
PASSWORD_REQUIRE_LOWER=0
PASSWORD_REQUIRE_NUMBER=1
PASSWORD_REQUIRE_SYMBOL=0
PASSWORD_EXPIRATION_DAYS=0
UPLOAD_MAX_FILE_SIZE_MB=15

# Seed admin (first access)
SEED_ADMIN_NAME="Administrador Sistema"
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me

# Deploy script (optional)
# Command executed after deploy.sh --apply (example only):
# DEPLOY_RESTART_COMMAND="sudo systemctl reload apache2"
DEPLOY_RESTART_COMMAND=

# Health path used by scripts/healthcheck.sh
DEPLOY_HEALTH_PATH=/health

# Backup/restore scripts (optional)
BACKUP_ROOT=/var/backups/reembolso
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_ENV=0

# KPI snapshots (optional)
OPS_KPI_SNAPSHOT_DIR=storage/ops/kpi_snapshots
OPS_KPI_SNAPSHOT_RETENTION_DAYS=30
OPS_KPI_SNAPSHOT_MAX_AGE_MINUTES=240
OPS_HEALTH_PANEL_SNAPSHOT_DIR=storage/ops/health-panel
OPS_LOG_SEVERITY_SNAPSHOT_DIR=storage/ops/log-severity

# FTP upload script (optional, used by scripts/ftp-upload.sh)
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=ftp_user
FTP_PASS=change_me
FTP_REMOTE_ROOT=/public_html/reembolso
FTP_IGNORE_FILE=.ftpignore
FTP_DELETE=0
FTP_SSL_ALLOW=0
FTP_SSL_FORCE=0
FTP_SSL_VERIFY=1
FTP_PARALLEL=2
