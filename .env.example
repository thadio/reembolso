# Aplicacao
NAME="Reembolso"
BASE_URL=http://localhost:8000
TIMEZONE=America/Sao_Paulo
APP_ENV=local
APP_DEBUG=1

# Banco de dados principal
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=reembolso
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_TIMEZONE=America/Sao_Paulo

# Seguranca de sessao e login
SESSION_NAME=reembolso_session
SESSION_TTL_SECONDS=7200
CSRF_TTL_SECONDS=7200
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_SECONDS=900

# Upload, cache e e-mail (modulos atuais/futuros)
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:8000/uploads
UPLOAD_TEMP=runtime/temp

CACHE_DRIVER=file
CACHE_PATH=runtime/cache

MAIL_MAILER_DRIVER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME="Reembolso"

# Parametros de imagens (modulos futuros)
THUMBNAIL_MAX_SIZE=320
PRODUCT_IMAGE_DIR=storage/products
PRODUCT_IMAGE_MAX_DIMENSION=1920
PRODUCT_IMAGE_MAX_SIZE_MB=5
PRODUCT_IMAGE_MAX_FILES=5
PRODUCT_IMAGE_JPEG_QUALITY=82
PRODUCT_IMAGE_WEBP_QUALITY=80
PRODUCT_IMAGE_PNG_COMPRESSION=8

# Base auxiliar CEP (opcional)
CEP_DB_HOST=127.0.0.1
CEP_DB_PORT=3306
CEP_DB_NAME=cep
CEP_DB_USER=cep_user
CEP_DB_PASS=
CEP_DB_CHARSET=utf8mb4

# FTP (opcional)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASS=

# Deploy remoto via scripts/deploy.sh
DEPLOY_SSH_HOST=
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=
DEPLOY_SSH_PASS=
DEPLOY_SSH_REMOTE_ROOT=/path/to/reembolso
DEPLOY_IGNORE_FILE=.ftpignore
DEPLOY_RSYNC_DELETE=0

# Seed inicial
SEED_ADMIN_NAME="Administrador Sistema"
SEED_ADMIN_EMAIL=admin@reembolso.local
SEED_ADMIN_PASSWORD=ChangeMe123!
